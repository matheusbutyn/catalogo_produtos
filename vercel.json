{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/enviar-produto", "destination": "/server.js" },
    { "source": "/produtos", "destination": "/server.js" },
    { "source": "/produtos/:id", "destination": "/server.js" }
  ]
}